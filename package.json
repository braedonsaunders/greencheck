{
  "name": "greencheck",
  "version": "0.1.1",
  "description": "GitHub Action that autonomously fixes CI failures using LLM-powered coding agents",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/braedonsaunders/greencheck"
  },
  "keywords": [
    "github-action",
    "ci",
    "auto-fix",
    "llm",
    "claude",
    "codex"
  ],
  "author": "Braedon Saunders",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "adm-zip": "^0.5.16",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.3.4"
  },
  "overrides": {
    "@actions/http-client": "^3.0.2",
    "undici": "^6.24.1",
    "@octokit/plugin-paginate-rest": "9.2.2",
    "@octokit/request": "8.4.1",
    "@octokit/request-error": "5.1.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
